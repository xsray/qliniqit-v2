# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Supabase database URL works here)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret   # found in Supabase dashboard > Settings > API

# App secrets (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-minimum-32-characters-long
CRON_SECRET=change-me-minimum-16-chars
UNSUBSCRIBE_SECRET=change-me-minimum-16-chars

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS S3 (or compatible — e.g. Supabase Storage, Cloudflare R2)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=qliniqit-uploads

# ─── Optional services ────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-...
RESEND_API_KEY=re_...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
DAILY_API_KEY=...
MUX_TOKEN_ID=...
MUX_TOKEN_SECRET=...
FIREBASE_PROJECT_ID=...
FIREBASE_CLIENT_EMAIL=...
FIREBASE_PRIVATE_KEY=...

# ─── Client (Vite — must be prefixed VITE_) ───────────────────────────────────

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_URL=http://localhost:3000
